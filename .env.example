# Firebase web app config. These values are public client config, but keep the real .env local.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Drive integration.
# Use a folder ID from a company Drive folder URL:
# https://drive.google.com/drive/folders/<THIS_PART_IS_THE_FOLDER_ID>
GOOGLE_DRIVE_FOLDER_ID=

# OAuth client JSON downloaded from Google Cloud Console.
# This lets Codex operate Drive after you approve access once.
GOOGLE_OAUTH_CREDENTIALS=google-credentials.json

# Token file generated by npm.cmd run drive:auth.
GOOGLE_OAUTH_TOKEN=token.json

# Service-account credentials can also be used later if you prefer that model.
GOOGLE_APPLICATION_CREDENTIALS=
